{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-check.sh",
            "timeout": 180,
            "statusMessage": "Running lint + tests..."
          }
        ]
      }
    ]
  }
}
